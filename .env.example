# Required app-facing settings
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_postgres_password
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=change_me_pgadmin_password
REDIS_PASSWORD=change_me_redis_password
GRAFANA_PASSWORD=change_me_grafana_password

# Public/local ports
PGBOUNCER_PORT=6543
PGBOUNCER_BIND_ADDR=0.0.0.0
POSTGRES_PORT=5432
POSTGRES_BIND_ADDR=127.0.0.1
PGADMIN_PORT=5050
REDIS_PORT=6379

# Backups: local + optional Cloudflare R2 upload
BACKUP_INTERVAL_SECONDS=43200
BACKUP_RETENTION=2
R2_BACKUP_ENABLED=false
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PREFIX=infra/
R2_MAX_BACKUPS_PER_DB=2

# Postgres image: default is custom build (PostGIS + pgvector + pg_cron)
# Override with a registry image (e.g. postgis/postgis:17-3.5-alpine) to skip the build
POSTGRES_IMAGE=infra/postgres:latest

# Optional monitoring and alerts
MONITORING_ENABLED=false
GRAFANA_PORT=3030
ALERT_EMAIL_TO=
ALERT_FROM=alerts@example.com
SMTP_SMARTHOST=smtp.gmail.com:587
SMTP_USER=
SMTP_PASSWORD=

# Cloudflare Tunnel (private access from Cloudflare edge for Hyperdrive/Workers)
CLOUDFLARE_TUNNEL_TOKEN=
