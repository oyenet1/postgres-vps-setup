# PostgreSQL Configuration
POSTGRES_VERSION=17
POSTGRES_DB=mydb
POSTGRES_USER=pguser
POSTGRES_PASSWORD=changeme_random_32_chars
POSTGRES_PORT=5432

# PgBouncer Configuration
PGBOUNCER_PORT=6543
PGBOUNCER_POOL_SIZE=20
PGBOUNCER_MAX_CLIENT_CONN=1000
PGBOUNCER_SERVER_LIFETIME=3600
PGBOUNCER_SERVER_IDLE_TIMEOUT=600

# pgAdmin Configuration
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=changeme_random_32_chars

# Backup Configuration
BACKUP_SCHEDULE="0 */12 * * *"
GOOGLE_DRIVE_REMOTE_NAME=gdrive
GOOGLE_DRIVE_FOLDER=postgres_backups
GOOGLE_DRIVE_TOKEN=your_token_here
GOOGLE_DRIVE_TEAM_DRIVE_ID=
RCLONE_CONFIG_PATH=/config/rclone/rclone.conf
MAX_BACKUPS=3

# Monitoring (optional - enables Prometheus + Grafana)
MONITORING_ENABLED=false
GRAFANA_PORT=3030
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin123

# Alert Configuration (optional - requires MONITORING_ENABLED=true)
ALERT_EMAIL_TO=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=
SMTP_FROM=alerts@example.com